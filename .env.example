# ---------------------------------------------------------------------------
# Public (client-side) configuration.
# Only VITE_-prefixed vars are exposed to the browser bundle. NEVER put a
# server secret (e.g. OPENROUTER_API_KEY, a service_role key) behind a VITE_
# prefix — it would ship to every visitor. Call those from an Edge Function.
# ---------------------------------------------------------------------------

# Supabase project (the anon key is safe for the client when RLS is enabled)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Brand / contact -----------------------------------------------------------
VITE_BRAND_NAME=HellIPTV

# Base of the external CTA link. The event title is appended (URL-encoded)
# to VITE_CTA_MESSAGE_TEMPLATE and passed as the message. Point this at a
# service you are licensed/authorised to provide.
# Example (WhatsApp):  https://wa.me/447411202861
VITE_CTA_BASE=https://wa.me/447411202861

# {event} is replaced with the event title. Keep it honest — no false claims.
VITE_CTA_MESSAGE_TEMPLATE=Hi, I'd like help watching {event}.

# Network test: a URL to time the round-trip against. Defaults to same-origin.
# Use a small, always-available resource (CDN ping, health endpoint, favicon).
VITE_LATENCY_TEST_URL=

# Canonical origin used for <link rel=canonical> and JSON-LD URLs.
VITE_SITE_ORIGIN=https://live.helliptv.com

# LibreSpeed speed-test backend. Default: the Supabase `speedtest` Edge Function
# (derived from VITE_SUPABASE_URL). Override for a dedicated LibreSpeed server.
VITE_SPEEDTEST_SERVER=

# ---------------------------------------------------------------------------
# Backend scripts (scripts/*.js) — NOT shipped to the browser. No VITE_ prefix.
# ---------------------------------------------------------------------------
# Required to RUN the ingest (writes to Supabase). Anon key is read-only (RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Public origin used to build page URLs for the sitemap + IndexNow submissions.
SITE_ORIGIN=https://live.helliptv.com
# IndexNow key (also hosted at SITE_ORIGIN/<key>.txt). Notifies Bing/Yandex.
INDEXNOW_KEY=
# TheSportsDB key (default '3' = public test key).
THESPORTSDB_API_KEY=3
# Broadcaster region stored on ingest (GB/US/MENA/INTL…).
DEFAULT_REGION=INTL

# OpenAI (server-side only). Set OPENAI_API_KEY as a Supabase Edge Function
# secret — NEVER commit it here:
#   supabase secrets set OPENAI_API_KEY=sk-...